# Server Configuration
PORT=8080

# MongoDB 配置
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=alchat

# Redis 配置
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI Compatible API Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# Expert Mode AI Configuration
EXPERT_API_KEY=your-expert-api-key-here
EXPERT_BASE_URL=https://api.openai.com/v1
EXPERT_MODEL=gpt-4

# Auth Configuration
JWT_SECRET=your_jwt_secret_here

# Title AI Configuration (Optional, defaults to OpenAI configuration)
TITLE_AI_MODEL=gpt-3.5-turbo
TITLE_AI_BASE_URL=https://api.openai.com/v1
TITLE_AI_API_KEY=your-api-key-here

# Aliyun OSS Configuration (Recommended Bucket ACL: Public Read, Private Write)
OSS_ENDPOINT=your-oss-endpoint (e.g., oss-cn-hangzhou.aliyuncs.com)
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=your-bucket-name

# Volcengine Image Generation Configuration
VOLCENGINE_API_KEY=your-volcengine-api-key
VOLCENGINE_IMAGE_EP=your-volcengine-endpoint-id (e.g., ep-xxxxxx-xxxx)

# Bocha AI Search Configuration
BOCHA_API_KEY=your-bocha-api-key

# Search Mode AI Configuration
SEARCH_API_KEY=your-search-api-key
SEARCH_BASE_URL=https://api.openai.com/v1
SEARCH_MODEL=gpt-4

# 多模态模型配置
MULTIMODAL_API_KEY=your-api-key-here
MULTIMODAL_BASE_URL=https://api.openai.com/v1
MULTIMODAL_MODEL=gpt-4o

# Agent 模型配置
AGENT_API_KEY=your-api-key-here
AGENT_BASE_URL=https://api.openai.com/v1
AGENT_MODEL=gpt-4o
